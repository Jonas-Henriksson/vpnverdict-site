---
import BaseLayout from './BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import VerdictBanner from '../components/VerdictBanner.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import { siteConfig } from '../site.config';
import ExitIntentCapture from '../components/ExitIntentCapture.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import ProductBanner from '../components/ProductBanner.astro';
import EzoicAds from '../components/EzoicAds.astro';
import AuthorBio from '../components/AuthorBio.astro';
import { authors, getAuthorByName } from '../authors';

export interface Props {
  title: string;
  description: string;
  date: Date;
  category?: string;
  author?: string;
  updated?: Date;
  vpnRatings?: Record<string, any>;
  affiliateLinks?: Array<{ vpn: string; url: string }>;
  faqPairs?: Array<{ question: string; answer: string }>;
  score?: number;
  badge?: string;
  verdict?: string;
  winner?: string;
  headings?: any[];
  currentSlug?: string;
  relatedArticles?: string[];
}

const {
  title,
  description,
  date,
  category,
  author = 'VPNVerdict Team',
  updated,
  vpnRatings = {},
  affiliateLinks = [],
  faqPairs = [],
  score,
  badge,
  verdict,
  winner,
  headings = [],
  currentSlug = '',
  relatedArticles = [],
} = Astro.props;
const hasAffiliateProducts = affiliateLinks.length > 0;

const publishedDate = new Date(date);
const formattedDate = publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const badgeLabels: Record<string, string> = {
  'editors-pick': "Editor's Pick",
  'best-value': 'Best Value',
  'top-rated': 'Top Rated',
  'tested': 'Tested',
};

// Author persona lookup
const authorData = getAuthorByName(author);
const authorSlug = authorData?.slug || '';
const authorTitle = authorData?.title || '';
const authorInitials = authorData?.initials || '';
const authorYears = authorData?.years || 0;
const structuredData: Record<string, any>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    image: 'https://vpnverdict.net/og-image.png',
    datePublished: publishedDate.toISOString(),
    dateModified: updated?.toISOString() || publishedDate.toISOString(),
    author: authorData ? { '@type': 'Person', name: authorData.name, jobTitle: authorData.title, url: `/author/${authorData.slug}` } : { '@type': 'Organization', name: 'VPNVerdict' },
  },
];

if (faqPairs.length > 0) {
  structuredData.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqPairs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  });
}

// Product/Review schema for articles with scores
const starRating = score ? Math.round((score / 10) * 5 * 10) / 10 : null;
if (score && starRating) {
  structuredData.push({
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: title.replace(/best\s+/i, '').replace(/\s*\d{4}.*$/, '').trim() || title,
    description,
    review: {
      '@type': 'Review',
      reviewRating: { '@type': 'Rating', ratingValue: starRating, bestRating: 5, worstRating: 1 },
      author: authorData ? { '@type': 'Person', name: authorData.name, jobTitle: authorData.title, url: `/author/${authorData.slug}` } : { '@type': 'Organization', name: 'VPNVerdict' },
      datePublished: publishedDate.toISOString(),
      reviewBody: verdict || description,
    },
  });
}

// BreadcrumbList schema
structuredData.push({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    ...(category ? [{ '@type': 'ListItem', position: 2, name: category.charAt(0).toUpperCase() + category.slice(1), item: siteConfig.url }] : []),
    { '@type': 'ListItem', position: category ? 3 : 2, name: title },
  ],
});

---

<BaseLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <article class="article">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      {category && (
        <>
          <span>{category.charAt(0).toUpperCase() + category.slice(1)}</span>
          <span class="breadcrumb-sep">/</span>
        </>
      )}
      <span class="breadcrumb-current">Review</span>
    </nav>

    <!-- Article Header -->
    <header class="article-header">
      <div class="header-top-row">
        <div class="header-labels">
          {category && <span class="article-category">{category.charAt(0).toUpperCase() + category.slice(1)}</span>}
          {badge && (
            <span class:list={['header-badge', `header-badge--${badge}`]}>
              {badge === 'editors-pick' && <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 0l1.5 3.1L10 3.6 7.5 6l.6 3.5L5 7.8 1.9 9.5l.6-3.5L0 3.6l3.5-.5L5 0z" fill="currentColor"/></svg>}
              {badgeLabels[badge] || badge}
            </span>
          )}
        </div>
        {score && (
          <div class="header-score">
            <span class="header-score-value">{score.toFixed(1)}</span>
            <span class="header-score-max">/10</span>
          </div>
        )}
      </div>
      <h1>{title}</h1>
      <p class="article-lede">{description}</p>
      <div class="article-meta">
        <div class="meta-left">
          <span class="meta-author">{author}</span>
          <span class="meta-sep">&middot;</span>
          <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
        </div>
      </div>
      <div class="header-rule"></div>
    </header>

    <!-- Author Bio -->
    {authorData && (
      <AuthorBio
        name={authorData.name}
        slug={authorData.slug}
        title={authorData.title}
        niche="VPNs"
        yearsExperience={authorData.years}
        initials={authorData.initials}
        image={authorData.image}
      />
    )}

    <!-- Verdict Banner -->
    <VerdictBanner score={score} verdict={verdict} winner={winner} badge={badge} />

    <!-- Where to Buy -->
    {hasAffiliateProducts && (
      <section class="where-to-buy">
        <h3 class="wtb-title">Where to Buy</h3>
        <div class="wtb-cards">
          {affiliateLinks.map((item) => (
            <div class="wtb-card">
              <span class="wtb-product">{item.vpn}</span>
              <a href={item.url} rel="nofollow sponsored external" target="_blank" class="affiliate-link">
                Visit {item.vpn}
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 11L11 1M11 1H5M11 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- FTC Affiliate Disclosure -->
    <p class="affiliate-disclosure">
      This article contains affiliate links. We may earn a commission at no extra cost to you.
      <a href="/disclosure">Full disclosure</a>
    </p>

    <!-- Content -->
    <div class="article-content">
      <slot />
                <EzoicAds placement="mid-article" />
<ProductBanner />
<LeadMagnetCTA siteId="vpnverdict" siteName="VPNVerdict" niche="vpn" />
    </div>

    <!-- Related Articles -->
        <EzoicAds placement="between-cards" />
    <RelatedArticles currentSlug={currentSlug} category={category} relatedSlugs={relatedArticles} />

    <!-- Newsletter -->
        <EzoicAds placement="bottom" />
    <NewsletterSignup variant="inline" />

    <!-- Disclosure -->
    <aside class="disclosure-box">
      <div class="disclosure-icon">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M10 18a8 8 0 100-16 8 8 0 000 16zM10 6v4m0 4h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="disclosure-content">
        <h4>Affiliate Disclosure</h4>
        <p>{siteConfig.siteName} earns commissions from affiliate links. This supports our independent testing at no cost to you. <a href="/disclosure">Full methodology &rarr;</a></p>
      </div>
    </aside>
      <ExitIntentCapture siteId="vpnverdict" siteName="VPNVerdict" niche="vpn" />
  </article>
</BaseLayout>

<style>
  .article {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* ── Breadcrumb ──────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-400);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb a { color: var(--ink-500); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-950); }
  .breadcrumb-sep { color: var(--ink-300); }
  .breadcrumb-current { color: var(--ink-400); }

  /* ── Article Header ──────────────────────────────── */
  .article-header {
    margin-bottom: var(--space-xl);
    animation: fadeInUp var(--duration-slow) var(--ease-out) both;
  }

  .header-top-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .header-labels { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }

  .article-category {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--electric);
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .header-badge--editors-pick { background: var(--amber-light); color: var(--amber); }
  .header-badge--top-rated { background: var(--electric-light); color: var(--electric); }
  .header-badge--best-value { background: var(--emerald-light); color: var(--emerald); }
  .header-badge--tested { background: var(--ink-50); color: var(--ink-500); }

  .header-score { display: flex; align-items: baseline; gap: 2px; flex-shrink: 0; }

  .header-score-value {
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink-950);
  }

  .header-score-max { font-size: 0.85rem; font-weight: 500; color: var(--ink-400); }

  .article-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }

  .article-lede {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--ink-500);
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    font-size: 0.85rem;
    color: var(--ink-500);
    margin-bottom: var(--space-lg);
  }

  .meta-left { display: flex; align-items: center; gap: 0.5rem; }
  .meta-author { font-weight: 600; color: var(--ink-700); }
  .meta-sep { color: var(--ink-300); }

  .header-rule { height: 2px; background: var(--ink-950); width: 48px; }

  /* ── Affiliate Disclosure (top) ───────────────────── */
  .affiliate-disclosure {
    font-size: 0.75rem;
    color: var(--ink-400, #6b7280);
    margin: 0.5rem 0 1.5rem;
    padding: 0;
    line-height: 1.4;
  }
  .affiliate-disclosure a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Content ────────────────────────────────────── */
  .article-content {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .article-content :global(h2) {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--ink-100);
  }

  .article-content :global(h2:first-child) { border-top: none; padding-top: 0; margin-top: 0; }

  .article-content :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .article-content :global(p) { margin-bottom: var(--space-lg); color: var(--ink-800); }
  .article-content :global(ul), .article-content :global(ol) { margin-bottom: var(--space-lg); padding-left: 1.75rem; }
  .article-content :global(li) { margin-bottom: var(--space-sm); color: var(--ink-800); }
  .article-content :global(strong) { color: var(--ink-950); font-weight: 600; }

  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xl) 0;
    font-size: 0.925rem;
    border: 1px solid var(--ink-100);
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .article-content :global(thead) { background: var(--ink-950); color: white; }
  .article-content :global(th) { padding: 0.75rem var(--space-md); text-align: left; font-weight: 600; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; border: none; }
  .article-content :global(td) { padding: 0.75rem var(--space-md); border-bottom: 1px solid var(--ink-100); }
  .article-content :global(tbody tr:last-child td) { border-bottom: none; }
  .article-content :global(tbody tr:hover) { background: var(--ink-50); }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--ink-950);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-xl) 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--ink-600);
    background: var(--surface-raised);
    border-radius: 0 var(--border-radius) var(--border-radius) 0;
  }

  /* ── Disclosure Box ──────────────────────────────── */
  .disclosure-box {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-lg);
    border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg);
    background: var(--ink-50);
    margin-top: var(--space-2xl);
  }

  .disclosure-icon { flex-shrink: 0; color: var(--ink-400); margin-top: 2px; }

  .disclosure-content h4 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--ink-700);
    margin-bottom: var(--space-xs);
  }

  .disclosure-content p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--ink-500);
    margin: 0;
  }

  .disclosure-content a {
    color: var(--ink-600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Responsive ──────────────────────────────────── */
  /* ── Affiliate Link Buttons (rehype-injected class) ── */
  .article-content :global(a.affiliate-link),
  a.affiliate-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-950);
    background: var(--surface, #fff);
    border: 1.5px solid var(--ink-950);
    border-radius: var(--border-radius, 6px);
    text-decoration: none;
    transition: all 0.15s ease-out;
    white-space: nowrap;
  }

  .article-content :global(a.affiliate-link:hover),
  a.affiliate-link:hover {
    background: var(--ink-950);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  }

  .article-content :global(a.affiliate-link svg),
  a.affiliate-link svg {
    opacity: 0.6;
    transition: opacity 0.15s ease-out, transform 0.15s ease-out;
    flex-shrink: 0;
  }

  .article-content :global(a.affiliate-link:hover svg),
  a.affiliate-link:hover svg {
    opacity: 1;
    transform: translate(1px, -1px);
  }

  /* ── Where to Buy Section ─────────────────────────── */
  .where-to-buy {
    margin: var(--space-lg, 1.5rem) 0;
    padding: var(--space-lg, 1.5rem);
    border: 1px solid var(--ink-100, #e5e7eb);
    border-radius: var(--border-radius-lg, 12px);
    background: var(--surface-raised, #fafafa);
  }

  .wtb-title {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-500, #6b7280);
    margin: 0 0 var(--space-md, 1rem) 0;
  }

  .wtb-cards {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md, 1rem);
  }

  .wtb-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md, 1rem);
    flex: 1 1 280px;
    padding: var(--space-md, 1rem);
    background: var(--surface, #fff);
    border: 1px solid var(--ink-100, #e5e7eb);
    border-radius: var(--border-radius, 6px);
  }

  .wtb-product {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-950, #111);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 640px) {
    .article-header h1 { font-size: 1.75rem; }
    .article-lede { font-size: 1.05rem; }
    .header-score-value { font-size: 1.75rem; }
    .disclosure-box { flex-direction: column; gap: var(--space-sm); }
    .wtb-card { flex-direction: column; align-items: flex-start; }
  }

  /* ── Dark Mode Overrides ──────────────────────────── */
  @media (prefers-color-scheme: dark) {
    .article-content :global(thead) { background: #111318; }
    .article-content :global(table) { border-color: #1c1c21; }
    .article-content :global(td) { border-bottom-color: #1c1c21; }
    .article-content :global(tbody tr:hover) { background: #161b26; }
    .article-content :global(blockquote) { background: #111318; border-left-color: #e8ecf1; }
    .article-content :global(h2) { border-top-color: #1c1c21; }
    .disclosure-box { background: #111318; border-color: #1c1c21; }
    .where-to-buy { background: #111318; border-color: #1c1c21; }
    .wtb-card { background: #0a0a0b; border-color: #1c1c21; }
    .header-rule { background: #e8ecf1; }
    a.affiliate-link,
    .article-content :global(a.affiliate-link) {
      background: #0a0a0b;
      border-color: #333a4a;
      color: #e8ecf1;
    }
    a.affiliate-link:hover,
    .article-content :global(a.affiliate-link:hover) {
      background: #e8ecf1;
      color: #0a0a0b;
    }
  }
</style>
