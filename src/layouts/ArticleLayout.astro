---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  author?: string;
  updated?: Date;
  vpnRatings?: Record<string, any>;
  affiliateLinks?: Array<{ vpn: string; url: string }>;
}

const {
  title,
  description,
  date,
  category,
  author = 'VPNVerdict Team',
  updated,
  vpnRatings = {},
  affiliateLinks = [],
} = Astro.props;

const formatDate = (d: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(d);
};

const categoryColors: Record<string, string> = {
  privacy: '#10b981',
  streaming: '#06b6d4',
  speed: '#f59e0b',
  security: '#ef4444',
  business: '#8b5cf6',
  gaming: '#ec4899',
};

const categoryColor = categoryColors[category] || '#10b981';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  'headline': title,
  'description': description,
  'image': 'https://vpnverdict.net/og-image.png',
  'datePublished': date.toISOString(),
  'dateModified': updated?.toISOString() || date.toISOString(),
  'author': {
    '@type': 'Organization',
    'name': 'VPNVerdict',
  },
};
---

<BaseLayout
  title={title}
  description={description}
  structuredData={structuredData}
>
  <article class="article-container">
    <div class="article-header">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/">Reviews</a>
          <span>/</span>
          <span>{title}</span>
        </div>

        <h1>{title}</h1>
        <p class="article-meta">
          By {author} | {formatDate(date)}
          {updated && <span> | Updated {formatDate(updated)}</span>}
        </p>

        <div class="category-badge" style={`background-color: ${categoryColor}20; border-left: 4px solid ${categoryColor}`}>
          <span class="category-label" style={`color: ${categoryColor}`}>
            {category.charAt(0).toUpperCase() + category.slice(1)}
          </span>
        </div>
      </div>
    </div>

    <div class="article-content">
      <div class="container">
        <div class="content-wrapper">
          <div class="main-content">
            <slot />
          </div>

          <aside class="sidebar">
            {affiliateLinks.length > 0 && (
              <div class="affiliate-box">
                <h3>Quick Links</h3>
                <div class="affiliate-buttons">
                  {affiliateLinks.map((link) => (
                    <a href={link.url} class="cta-button" target="_blank" rel="noopener noreferrer">
                      Visit {link.vpn}
                    </a>
                  ))}
                </div>
              </div>
            )}

            {Object.keys(vpnRatings).length > 0 && (
              <div class="vpn-ratings-box">
                <h3>VPN Ratings</h3>
                <div class="ratings-list">
                  {Object.entries(vpnRatings).map(([vpnKey, vpn]: [string, any]) => (
                    <div class="rating-item">
                      <div class="rating-header">
                        <h4>{vpn.name}</h4>
                        <div class="stars">
                          {'★'.repeat(Math.floor(vpn.rating))}{vpn.rating % 1 !== 0 ? '½' : ''}
                        </div>
                      </div>
                      <p class="rating-value">{vpn.rating}/5</p>
                      {vpn.affiliateLink && (
                        <a href={vpn.affiliateLink} class="rating-link" target="_blank" rel="noopener noreferrer">
                          View Details →
                        </a>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div class="info-box">
              <h4>About This Article</h4>
              <p>VPNVerdict reviews are based on rigorous testing, hands-on experience, and comprehensive analysis of VPN services. Our recommendations are independent and not influenced by affiliate relationships.</p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </article>

  <style is:global>
    .article-container {
      background-color: #0f1419;
    }

    .article-header {
      background: linear-gradient(135deg, #0f1419 0%, #1a1f2b 100%);
      border-bottom: 1px solid #1a1f2b;
      padding: 3rem 0;
      margin-bottom: 3rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      color: #a8b3bf;
    }

    .breadcrumb a {
      color: #10b981;
    }

    .article-header h1 {
      margin-bottom: 1rem;
      max-width: 900px;
    }

    .article-meta {
      color: #a8b3bf;
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    .category-badge {
      display: inline-block;
      padding: 0.5rem 1rem;
      border-radius: 0.25rem;
      margin-bottom: 1rem;
    }

    .category-label {
      font-weight: 600;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .article-content {
      padding: 0;
    }

    .content-wrapper {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 3rem;
    }

    .main-content {
      line-height: 1.8;
      font-size: 1.05rem;
    }

    .main-content p {
      margin-bottom: 1.5rem;
      color: #d1d8e0;
    }

    .main-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      background-color: #1a1f2b;
      border-radius: 0.5rem;
      overflow: hidden;
    }

    .main-content th {
      background-color: #0f1419;
      color: #ffffff;
      padding: 1rem;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid #10b981;
    }

    .main-content td {
      padding: 1rem;
      border-bottom: 1px solid #2d3748;
    }

    .main-content tr:last-child td {
      border-bottom: none;
    }

    .main-content strong {
      color: #ffffff;
      font-weight: 600;
    }

    .main-content em {
      color: #10b981;
      font-style: italic;
    }

    .sidebar {
      position: sticky;
      top: 90px;
      height: fit-content;
    }

    .affiliate-box,
    .vpn-ratings-box,
    .info-box {
      background-color: #1a1f2b;
      border: 1px solid #2d3748;
      border-radius: 0.5rem;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .affiliate-box h3,
    .vpn-ratings-box h3 {
      font-size: 1.1rem;
      margin-bottom: 1rem;
      color: #ffffff;
    }

    .affiliate-buttons {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .cta-button {
      display: block;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: #ffffff;
      padding: 0.75rem 1rem;
      border-radius: 0.375rem;
      text-align: center;
      font-weight: 600;
      transition: all 0.3s ease;
      font-size: 0.9rem;
    }

    .cta-button:hover {
      background: linear-gradient(135deg, #059669 0%, #047857 100%);
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .ratings-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .rating-item {
      padding-bottom: 1rem;
      border-bottom: 1px solid #2d3748;
    }

    .rating-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .rating-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.5rem;
    }

    .rating-header h4 {
      font-size: 0.95rem;
      margin: 0;
      color: #ffffff;
    }

    .stars {
      color: #f59e0b;
      font-size: 0.9rem;
    }

    .rating-value {
      font-size: 0.9rem;
      color: #10b981;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .rating-link {
      font-size: 0.85rem;
      color: #10b981;
    }

    .info-box h4 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    .info-box p {
      font-size: 0.9rem;
      margin-bottom: 0;
      color: #a8b3bf;
    }

    @media (max-width: 768px) {
      .article-header {
        padding: 2rem 0;
        margin-bottom: 2rem;
      }

      .content-wrapper {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .sidebar {
        position: static;
      }

      .main-content table {
        font-size: 0.9rem;
      }

      .main-content th,
      .main-content td {
        padding: 0.75rem;
      }
    }
  </style>
</BaseLayout>
