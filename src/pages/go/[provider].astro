---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const providers = [
    { provider: 'nordvpn', name: 'NordVPN', url: 'https://www.anrdoezrs.net/click-101724885-16968809' },
    { provider: 'expressvpn', name: 'ExpressVPN', url: 'https://go.expressvpn.com/c/7170259/1462856/16063' },
    { provider: 'surfshark', name: 'Surfshark', url: 'https://www.anrdoezrs.net/click-101724885-15438560' },
    { provider: 'cyberghost', name: 'CyberGhost', url: 'https://cyberghostvpn.com' },
    { provider: 'protonvpn', name: 'ProtonVPN', url: 'https://www.jdoqocy.com/click-101724885-15834536-1774304322000' },
    { provider: 'nordpass', name: 'NordPass', url: 'https://www.kqzyfj.com/click-101724885-17262576' },
    { provider: 'proton-partners-program', name: 'Proton Partners Program', url: 'https://www.jdoqocy.com/click-101724885-15834536-1774304322000' },
    { provider: 'iolo-system-mechanic', name: 'Iolo System Mechanic', url: 'https://www.jdoqocy.com/click-101724885-10783204-1749144832000' },
    { provider: 'surfshark-vpn', name: 'Surfshark VPN', url: 'https://get.surfshark.net/aff_c?offer_id=926&aff_id=46109' },
    { provider: 'surfshark-antivirus', name: 'Surfshark Antivirus', url: 'https://get.surfshark.net/aff_c?offer_id=934&aff_id=46109' },
    { provider: 'kaspersky-lab-denmark-aps-nordics', name: 'Kaspersky Lab Denmark ApS (Nordics)', url: 'https://www.tkqlhce.com/click-101724885-14304704-1766431593000' },
    { provider: 'roboform-password-manager-affiliate-program', name: 'RoboForm Password Manager Affiliate Program', url: 'https://www.kqzyfj.com/click-101724885-13790972-1765516111000' },
  ];
  return providers.map((p) => ({
    params: { provider: p.provider },
    props: { name: p.name, url: p.url },
  }));
}

const { name, url } = Astro.props;
---

<BaseLayout title={`Visit ${name}`} description={`Redirecting to ${name} - recommended by VPNVerdict`}>
  <div class="redirect-page">
    <h1>Redirecting to {name}...</h1>
    <p>You're being redirected to {name}. If you're not redirected automatically, <a href={url} rel="nofollow sponsored">click here</a>.</p>
    <p class="disclosure">VPNVerdict may earn a commission if you sign up through this link. This doesn't affect our reviews or recommendations.</p>
  </div>
</BaseLayout>

<script define:vars={{ url }}>
  setTimeout(() => { window.location.href = url; }, 1500);
</script>

<style>
  .redirect-page {
    text-align: center;
    padding: 6rem 1rem;
  }

  .redirect-page h1 {
    font-size: 1.5rem;
    color: #ffffff;
    margin-bottom: 1rem;
  }

  .redirect-page p {
    color: #a8b3bf;
    margin-bottom: 1rem;
  }

  .disclosure {
    font-size: 0.85rem;
    color: #6b7280;
    margin-top: 2rem;
  }
</style>
