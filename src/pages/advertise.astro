---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Advertise With VPNVerdict" description="Partner with VPNVerdict to reach 38,000+ monthly readers in the VPN and online privacy space. Sponsored reviews, banner placements, and newsletter sponsorships.">
  <article class="advertise-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Advertise</span>
    </nav>

    <header class="page-header">
      <span class="page-label">Partnerships</span>
      <h1>Partner With VPNVerdict</h1>
      <p class="header-sub">Reach a highly engaged audience of privacy-conscious consumers and IT professionals through trusted, editorially independent content.</p>
      <div class="header-rule"></div>
    </header>

    <section class="audience-stats">
      <h2>Our Audience</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number">38,000+</span>
          <span class="stat-label">Monthly Readers</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">4.2 min</span>
          <span class="stat-label">Avg. Time on Page</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">65%</span>
          <span class="stat-label">Purchase Intent</span>
        </div>
        <div class="stat-card">
          <span class="stat-number">12,000+</span>
          <span class="stat-label">Newsletter Subscribers</span>
        </div>
      </div>
      <p class="stats-note">Our readers are privacy-conscious consumers and IT professionals. They visit VPNVerdict when making informed buying decisions in the VPN and online privacy space.</p>
    </section>

    <section class="sponsorship-options">
      <h2>Sponsorship Options</h2>
      <div class="options-grid">
        <div class="option-card">
          <div class="option-header">
            <h3>Sponsored Review</h3>
            <span class="price">$500 -- $1,500</span>
          </div>
          <p>A full hands-on review of your product written by our editorial team. Includes real testing, honest scoring, and affiliate link integration. Published permanently on the site with full SEO optimization.</p>
          <ul>
            <li>In-depth, hands-on product evaluation</li>
            <li>Published as a permanent article with SEO</li>
            <li>Shared across our social channels</li>
            <li>Clearly labeled as sponsored content</li>
          </ul>
        </div>

        <div class="option-card">
          <div class="option-header">
            <h3>Banner Placement</h3>
            <span class="price">$200 -- $800/mo</span>
          </div>
          <p>High-visibility banner ads placed in our sidebar or within article content. Targeted to readers actively researching VPN and online privacy products and solutions.</p>
          <ul>
            <li>Sidebar or in-article placement options</li>
            <li>Desktop and mobile responsive formats</li>
            <li>Monthly performance reporting</li>
            <li>Minimum 30-day commitment</li>
          </ul>
        </div>

        <div class="option-card">
          <div class="option-header">
            <h3>Newsletter Sponsorship</h3>
            <span class="price">$150 -- $400</span>
          </div>
          <p>Featured placement in our weekly email digest sent to 12,000+ subscribers. Your product in front of a highly engaged audience who opted in for VPN and online privacy recommendations.</p>
          <ul>
            <li>Featured slot in the weekly digest</li>
            <li>Custom copy with your messaging</li>
            <li>Direct link to your landing page</li>
            <li>Open rate and click-through reporting</li>
          </ul>
        </div>

        <div class="option-card">
          <div class="option-header">
            <h3>Content Collaboration</h3>
            <span class="price">Custom Pricing</span>
          </div>
          <p>Tailored partnerships including co-branded guides, comparison features, exclusive deals for our audience, or multi-channel campaigns. We work with you to design something that fits.</p>
          <ul>
            <li>Co-branded guides and resources</li>
            <li>Exclusive deals for our readers</li>
            <li>Multi-channel campaign support</li>
            <li>Flexible scope and timeline</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="why-partner">
      <h2>Why Partner With Us</h2>
      <div class="why-grid">
        <div class="why-item">
          <h3>Editorial Integrity</h3>
          <p>We maintain strict editorial independence. Sponsored content is always clearly labeled, and our reviews reflect genuine testing. This honesty is why our readers trust us -- and why your brand benefits from that trust.</p>
        </div>
        <div class="why-item">
          <h3>Niche Authority</h3>
          <p>VPNVerdict is a focused publication covering VPN and online privacy. Our readers are not casual browsers -- they are actively researching products and making purchasing decisions in this space.</p>
        </div>
        <div class="why-item">
          <h3>High-Intent Audience</h3>
          <p>With 65% of our audience reporting purchase intent within 30 days, your sponsorship reaches people who are ready to buy. Our content ranks for commercial and transactional keywords that drive conversions.</p>
        </div>
        <div class="why-item">
          <h3>Transparent Reporting</h3>
          <p>Every sponsorship includes detailed performance reporting: impressions, clicks, engagement metrics, and conversion data where applicable. You always know what you are getting.</p>
        </div>
      </div>
    </section>

    <section class="media-kit">
      <div class="media-kit-card">
        <div class="media-kit-content">
          <h2>Download Our Media Kit</h2>
          <p>Get detailed audience demographics, traffic data, sponsorship specs, and case studies in our comprehensive media kit.</p>
        </div>
        <a href="#" class="btn-media-kit">Download Media Kit (PDF)</a>
      </div>
    </section>

    <section class="contact-form-section" id="contact">
      <h2>Get in Touch</h2>
      <p class="section-intro">Interested in partnering with VPNVerdict? Fill out the form below and we will get back to you within 2 business days.</p>
      <form class="contact-form" action="mailto:advertise@vpnverdict.net" method="POST" enctype="text/plain">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="Jane Smith" />
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="jane@company.com" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="company">Company</label>
            <input type="text" id="company" name="company" required placeholder="Acme Corp" />
          </div>
          <div class="form-group">
            <label for="budget">Budget Range</label>
            <select id="budget" name="budget" required>
              <option value="" disabled selected>Select a range</option>
              <option value="under-500">Under $500</option>
              <option value="500-1000">$500 -- $1,000</option>
              <option value="1000-2500">$1,000 -- $2,500</option>
              <option value="2500-5000">$2,500 -- $5,000</option>
              <option value="5000-plus">$5,000+</option>
            </select>
          </div>
        </div>
        <div class="form-group full-width">
          <label for="message">Tell Us About Your Goals</label>
          <textarea id="message" name="message" rows="5" required placeholder="What product or service would you like to promote? What are your campaign goals?"></textarea>
        </div>
        <button type="submit" class="btn-submit">Send Inquiry</button>
      </form>
      <p class="alt-contact">Prefer email? Reach us directly at <a href="mailto:advertise@vpnverdict.net">advertise@vpnverdict.net</a></p>
    </section>

    <footer class="disclosure-footer">
      <p>All sponsored content is clearly labeled in accordance with FTC guidelines. Sponsorship does not influence editorial scores or recommendations. See our <a href="/disclosure">full disclosure policy</a>.</p>
    </footer>
  </article>
</BaseLayout>

<style>
  .advertise-page { max-width: var(--max-width); margin: 0 auto; }

  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: var(--ink-400); margin-bottom: var(--space-xl);
  }
  .breadcrumb a { color: var(--ink-500); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-950); }
  .sep { color: var(--ink-300); }
  .current { color: var(--ink-400); }

  .page-header { margin-bottom: var(--space-2xl); animation: fadeInUp var(--duration-slow) var(--ease-out) both; }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .page-header h1 { margin-top: var(--space-sm); margin-bottom: var(--space-md); }
  .header-sub { color: var(--ink-600); font-size: 1.1rem; line-height: 1.6; max-width: 600px; }
  .header-rule { height: 2px; width: 48px; background: var(--electric); margin-top: var(--space-md); }

  /* Sections */
  section { margin-bottom: var(--space-2xl); }
  section h2 { margin-top: 0; margin-bottom: var(--space-md); padding-top: var(--space-xl); border-top: 1px solid var(--ink-100); }

  /* Audience Stats */
  .stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .stat-card {
    display: flex; flex-direction: column; align-items: center;
    padding: 1.5rem 1rem; border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg, 10px); background: var(--surface, #fff);
    text-align: center;
  }
  .stat-number { font-size: 1.75rem; font-weight: 700; color: var(--electric); line-height: 1.2; }
  .stat-label { font-size: 0.8rem; color: var(--ink-500); margin-top: 0.25rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .stats-note { color: var(--ink-600); line-height: 1.75; }

  /* Sponsorship Options */
  .options-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;
  }
  .option-card {
    padding: 1.5rem; border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg, 10px); background: var(--surface, #fff);
    transition: border-color 0.15s ease-out;
  }
  .option-card:hover { border-color: var(--electric); }
  .option-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem; flex-wrap: wrap; gap: 0.5rem; }
  .option-header h3 { margin: 0; font-size: 1.1rem; color: var(--ink-950); }
  .price { font-size: 0.9rem; font-weight: 600; color: var(--electric); white-space: nowrap; }
  .option-card p { color: var(--ink-600); line-height: 1.65; font-size: 0.92rem; margin-bottom: 0.75rem; }
  .option-card ul { list-style: none; padding: 0; margin: 0; }
  .option-card li {
    font-size: 0.85rem; color: var(--ink-500); padding: 0.3rem 0;
    padding-left: 1.25rem; position: relative;
  }
  .option-card li::before {
    content: ''; position: absolute; left: 0; top: 0.6rem;
    width: 6px; height: 6px; border-radius: 50%; background: var(--electric);
  }

  /* Why Partner */
  .why-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem;
  }
  .why-item {
    padding: 1.25rem 1.5rem; border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg, 10px); background: var(--surface, #fff);
  }
  .why-item h3 { margin: 0 0 0.5rem; font-size: 1rem; color: var(--ink-950); }
  .why-item p { color: var(--ink-600); line-height: 1.65; font-size: 0.92rem; margin: 0; }

  /* Media Kit */
  .media-kit-card {
    display: flex; align-items: center; justify-content: space-between;
    padding: 2rem; border: 2px solid var(--electric);
    border-radius: var(--border-radius-lg, 10px); background: var(--surface, #fff);
    gap: 2rem; flex-wrap: wrap;
  }
  .media-kit-content h2 { border-top: none; padding-top: 0; margin-bottom: 0.5rem; }
  .media-kit-content p { color: var(--ink-600); margin: 0; max-width: 480px; }
  .btn-media-kit {
    display: inline-block; padding: 0.75rem 1.75rem;
    background: var(--electric); color: #fff; font-weight: 600;
    border-radius: 6px; text-decoration: none; font-size: 0.95rem;
    transition: opacity 0.15s ease-out; white-space: nowrap;
  }
  .btn-media-kit:hover { opacity: 0.85; color: #fff; }

  /* Contact Form */
  .contact-form-section h2 { border-top: 1px solid var(--ink-100); padding-top: var(--space-xl); }
  .section-intro { color: var(--ink-500); margin-bottom: 1.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.35rem; }
  .form-group.full-width { grid-column: 1 / -1; }
  .form-group label { font-size: 0.85rem; font-weight: 600; color: var(--ink-700); }
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.65rem 0.85rem; border: 1px solid var(--ink-200);
    border-radius: 6px; font-size: 0.95rem; color: var(--ink-950);
    background: var(--surface, #fff); transition: border-color 0.15s ease-out;
    font-family: inherit;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none; border-color: var(--electric);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }
  .form-group textarea { resize: vertical; }
  .btn-submit {
    align-self: flex-start; padding: 0.75rem 2rem;
    background: var(--electric); color: #fff; font-weight: 600;
    border: none; border-radius: 6px; font-size: 0.95rem;
    cursor: pointer; transition: opacity 0.15s ease-out;
  }
  .btn-submit:hover { opacity: 0.85; }
  .alt-contact { margin-top: 1rem; font-size: 0.85rem; color: var(--ink-400); }
  .alt-contact a { color: var(--electric); font-weight: 600; }

  /* Disclosure Footer */
  .disclosure-footer {
    margin-top: var(--space-2xl); padding-top: var(--space-xl);
    border-top: 1px solid var(--ink-100);
  }
  .disclosure-footer p { font-size: 0.85rem; color: var(--ink-400); line-height: 1.65; }
  .disclosure-footer a { color: var(--ink-500); text-decoration: underline; text-underline-offset: 2px; }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .options-grid { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .media-kit-card { flex-direction: column; text-align: center; }
  }

  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
