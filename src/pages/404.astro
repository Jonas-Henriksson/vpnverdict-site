---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="not-found">
    <span class="not-found-code">404</span>
    <h1>Page not found.</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="back-link">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="back-arrow">
        <path d="M13 7H1m0 0l5 4.5M1 7l5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to reviews
    </a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: var(--space-4xl) var(--space-lg);
    max-width: 480px;
    margin: 0 auto;
  }

  .not-found-code {
    display: block;
    font-family: var(--font-display);
    font-size: 6rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink-100);
    margin-bottom: var(--space-md);
  }

  .not-found h1 { font-size: 1.75rem; margin-bottom: var(--space-sm); }
  .not-found p { color: var(--ink-500); margin-bottom: var(--space-xl); }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink-950);
    background: var(--surface);
    border: 1.5px solid var(--ink-950);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .back-link:hover { background: var(--surface-inverse); color: white; }
  .back-arrow { transition: transform var(--duration-fast) var(--ease-out); }
  .back-link:hover .back-arrow { transform: translateX(-3px); }
</style>
