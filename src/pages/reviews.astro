---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<BaseLayout title="All VPN Reviews" description="Browse all VPN reviews, comparisons, and guides. Find the best VPN for your needs.">
  <article class="page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Reviews</span>
    </nav>

    <header class="page-header">
      <span class="page-label">All Reviews</span>
      <h1>VPN reviews,<br/><em>scored and ranked.</em></h1>
      <div class="header-rule"></div>
    </header>

    <div class="articles-grid">
      {sorted.map((article, i) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          date={article.data.date}
          author={article.data.author}
          category={article.data.category}
          slug={article.slug}
          score={article.data.score}
          badge={article.data.badge}
          rank={i + 1}
        />
      ))}
    </div>
  </article>
</BaseLayout>

<style>
  .page { max-width: var(--max-width-wide); margin: 0 auto; }

  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: var(--ink-400); margin-bottom: var(--space-xl);
  }
  .breadcrumb a { color: var(--ink-500); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-950); }
  .sep { color: var(--ink-300); }
  .current { color: var(--ink-400); }

  .page-header { margin-bottom: var(--space-2xl); animation: fadeInUp var(--duration-slow) var(--ease-out) both; }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .page-header h1 { margin-top: var(--space-sm); margin-bottom: var(--space-md); }
  .page-header h1 em { font-style: italic; color: var(--ink-500); }
  .header-rule { height: 2px; width: 48px; background: var(--surface-inverse); }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-lg);
    padding-bottom: var(--space-3xl);
  }

  @media (max-width: 768px) {
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>
