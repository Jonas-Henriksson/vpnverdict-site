---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const comparisons = articles
  .filter((a) => {
    const t = a.data.title.toLowerCase();
    return t.includes(' vs ') || t.includes('comparison') || t.includes('best ');
  })
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categoryColors: Record<string, string> = {
  privacy: '#10b981',
  streaming: '#06b6d4',
  speed: '#f59e0b',
  security: '#ef4444',
  business: '#8b5cf6',
  gaming: '#ec4899',
};
---

<BaseLayout title="VPN Comparisons" description="Side-by-side VPN comparisons. NordVPN vs ExpressVPN, Surfshark vs CyberGhost, and more.">
  <div class="container">
    <div class="page-header">
      <h1>VPN Comparisons</h1>
      <p>Side-by-side comparisons to help you pick the best VPN for your needs</p>
    </div>

    <div class="articles-grid">
      {comparisons.map((article) => {
        const date = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(article.data.date);
        const color = categoryColors[article.data.category] || '#10b981';
        return (
          <article class="article-card">
            <div class="article-card-header">
              <span class="article-date">{date}</span>
              <span class="article-category" style={`background-color: ${color}20; color: ${color}`}>{article.data.category}</span>
            </div>
            <h3><a href={`/${article.slug}`}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
            <a href={`/${article.slug}`} class="article-link">Read Comparison</a>
          </article>
        );
      })}
    </div>

    {comparisons.length === 0 && (
      <p class="empty-state">No comparisons yet. Check back soon!</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    padding: 3rem 0;
    border-bottom: 1px solid #1a1f2b;
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: #a8b3bf;
    font-size: 1.1rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    padding-bottom: 3rem;
  }

  .article-card {
    background-color: #1a1f2b;
    border: 1px solid #2d3748;
    border-radius: 0.5rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .article-card:hover {
    border-color: #10b981;
    box-shadow: 0 8px 16px rgba(16, 185, 129, 0.15);
  }

  .article-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .article-date { color: #a8b3bf; font-size: 0.85rem; }

  .article-category {
    padding: 0.25rem 0.75rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .article-card h3 { margin-top: 0; margin-bottom: 0.75rem; font-size: 1.15rem; }
  .article-card h3 a { color: #ffffff; }
  .article-card h3 a:hover { color: #10b981; }
  .article-card p { color: #d1d8e0; margin-bottom: 1rem; font-size: 0.95rem; line-height: 1.6; }
  .article-link { color: #10b981; font-weight: 600; font-size: 0.9rem; }
  .empty-state { text-align: center; color: #a8b3bf; padding: 4rem 0; }
</style>
