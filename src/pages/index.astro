---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const featured = articles.filter((a) => a.data.featured).sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const latest = articles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 6);

const categories = ['privacy', 'streaming', 'speed', 'security', 'business', 'gaming'];
const categoryIcons: Record<string, string> = {
  privacy: '🔒',
  streaming: '🎬',
  speed: '⚡',
  security: '🛡️',
  business: '💼',
  gaming: '🎮',
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'VPNVerdict',
  'url': 'https://vpnverdict.net',
  'description': 'Comprehensive VPN reviews, comparisons, and guides.',
};
---

<BaseLayout
  title="Best VPN Reviews & Comparisons 2026"
  description="Find the perfect VPN service with VPNVerdict. Expert reviews, detailed comparisons, and honest recommendations for privacy, streaming, speed, and security."
  structuredData={structuredData}
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <h1>Find Your Perfect VPN</h1>
        <p class="hero-subtitle">Expert reviews, honest comparisons, and detailed guides for every VPN service on the market</p>
        <div class="hero-cta">
          <a href="#featured" class="btn btn-primary">View Top Picks</a>
          <a href="#categories" class="btn btn-secondary">Browse by Category</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="vpn-grid">
          <div class="vpn-card">NordVPN</div>
          <div class="vpn-card">ExpressVPN</div>
          <div class="vpn-card">Surfshark</div>
          <div class="vpn-card">CyberGhost</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Reviews -->
  {featured.length > 0 && (
    <section class="featured-section" id="featured">
      <div class="container">
        <div class="section-header">
          <h2>Featured Reviews</h2>
          <p>Our top-rated VPNs tested and reviewed by our experts</p>
        </div>

        <div class="featured-grid">
          {featured.map((article) => {
            const slug = article.slug;
            return (
              <article class="featured-card">
                <div class="card-header">
                  <h3><a href={`/${slug}`}>{article.data.title}</a></h3>
                  <span class="badge">{article.data.category}</span>
                </div>
                <p class="card-description">{article.data.description}</p>
                <a href={`/${slug}`} class="read-more">Read Full Review →</a>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="categories-section" id="categories">
    <div class="container">
      <div class="section-header">
        <h2>Browse by Category</h2>
        <p>Find VPNs tailored to your specific needs</p>
      </div>

      <div class="categories-grid">
        {categories.map((cat) => {
          const count = articles.filter((a) => a.data.category === cat).length;
          const icon = categoryIcons[cat] || '📌';
          return (
            <div class="category-item">
              <div class="category-icon">{icon}</div>
              <h3>{cat.charAt(0).toUpperCase() + cat.slice(1)}</h3>
              <p>{count} {count === 1 ? 'article' : 'articles'}</p>
              <a href={`/?category=${cat}`} class="category-link">Explore →</a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="latest-section">
    <div class="container">
      <div class="section-header">
        <h2>Latest Reviews & Guides</h2>
        <p>Stay updated with our newest VPN reviews and comparisons</p>
      </div>

      <div class="articles-grid">
        {latest.map((article) => {
          const slug = article.slug;
          const date = new Intl.DateTimeFormat('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          }).format(article.data.date);
          return (
            <article class="article-card">
              <div class="article-card-header">
                <span class="article-date">{date}</span>
                <span class="article-category">{article.data.category}</span>
              </div>
              <h3><a href={`/${slug}`}>{article.data.title}</a></h3>
              <p>{article.data.description}</p>
              <a href={`/${slug}`} class="article-link">Read Article →</a>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="latest-section">
    <div class="container">
      <NewsletterSignup variant="hero" />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Choose Your VPN?</h2>
        <p>Browse our comprehensive reviews and find the perfect VPN service for your needs. We've tested all major providers to bring you honest, detailed comparisons.</p>
        <a href="#latest" class="btn btn-primary">Start Exploring</a>
      </div>
    </div>
  </section>

  <style is:global>
    .hero {
      background: linear-gradient(135deg, #0f1419 0%, #1a1f2b 50%, #0f1419 100%);
      border-bottom: 1px solid #1a1f2b;
      padding: 5rem 0;
      margin-bottom: 4rem;
    }

    .hero .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: center;
    }

    .hero-content h1 {
      font-size: 3rem;
      margin-bottom: 1.5rem;
      background: linear-gradient(135deg, #ffffff 0%, #10b981 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-size: 1.25rem;
      color: #a8b3bf;
      margin-bottom: 2rem;
      line-height: 1.6;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
    }

    .btn {
      display: inline-block;
      padding: 0.875rem 2rem;
      border-radius: 0.375rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: #ffffff;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(16, 185, 129, 0.3);
    }

    .btn-secondary {
      background-color: transparent;
      color: #10b981;
      border: 2px solid #10b981;
    }

    .btn-secondary:hover {
      background-color: #10b98120;
    }

    .vpn-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .vpn-card {
      background: linear-gradient(135deg, #1a1f2b 0%, #2d3748 100%);
      border: 1px solid #10b981;
      border-radius: 0.5rem;
      padding: 2rem;
      text-align: center;
      font-weight: 600;
      color: #ffffff;
      transition: all 0.3s ease;
    }

    .vpn-card:hover {
      background: linear-gradient(135deg, #2d3748 0%, #3e4556 100%);
      box-shadow: 0 8px 16px rgba(16, 185, 129, 0.2);
      transform: translateY(-4px);
    }

    .featured-section,
    .categories-section,
    .latest-section {
      padding: 4rem 0;
      border-bottom: 1px solid #1a1f2b;
    }

    .section-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .section-header h2 {
      margin-top: 0;
      margin-bottom: 0.5rem;
    }

    .section-header p {
      color: #a8b3bf;
      font-size: 1.1rem;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .featured-card {
      background: linear-gradient(135deg, #1a1f2b 0%, #2d3748 100%);
      border: 1px solid #2d3748;
      border-radius: 0.5rem;
      padding: 2rem;
      transition: all 0.3s ease;
    }

    .featured-card:hover {
      border-color: #10b981;
      box-shadow: 0 8px 24px rgba(16, 185, 129, 0.15);
      transform: translateY(-4px);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .card-header h3 {
      margin: 0;
      font-size: 1.25rem;
    }

    .card-header a {
      color: #ffffff;
    }

    .card-header a:hover {
      color: #10b981;
    }

    .badge {
      background-color: #10b98120;
      color: #10b981;
      padding: 0.25rem 0.75rem;
      border-radius: 0.25rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .card-description {
      color: #d1d8e0;
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .read-more {
      color: #10b981;
      font-weight: 600;
      display: inline-block;
    }

    .read-more:hover {
      color: #059669;
    }

    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
    }

    .category-item {
      background-color: #1a1f2b;
      border: 1px solid #2d3748;
      border-radius: 0.5rem;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s ease;
    }

    .category-item:hover {
      border-color: #10b981;
      background-color: #1a1f2b;
      box-shadow: 0 8px 16px rgba(16, 185, 129, 0.1);
    }

    .category-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .category-item h3 {
      margin-top: 0;
      margin-bottom: 0.5rem;
    }

    .category-item p {
      color: #a8b3bf;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .category-link {
      color: #10b981;
      font-weight: 600;
    }

    .articles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .article-card {
      background-color: #1a1f2b;
      border: 1px solid #2d3748;
      border-radius: 0.5rem;
      padding: 1.5rem;
      transition: all 0.3s ease;
    }

    .article-card:hover {
      border-color: #10b981;
      box-shadow: 0 8px 16px rgba(16, 185, 129, 0.15);
    }

    .article-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      gap: 1rem;
    }

    .article-date {
      color: #a8b3bf;
      font-size: 0.85rem;
    }

    .article-category {
      background-color: #10b98120;
      color: #10b981;
      padding: 0.25rem 0.75rem;
      border-radius: 0.25rem;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .article-card h3 {
      margin-top: 0;
      margin-bottom: 0.75rem;
    }

    .article-card a {
      color: #ffffff;
    }

    .article-card a:hover {
      color: #10b981;
    }

    .article-card p {
      color: #d1d8e0;
      margin-bottom: 1rem;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .article-link {
      color: #10b981;
      font-weight: 600;
    }

    .article-link:hover {
      color: #059669;
    }

    .cta-section {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      padding: 4rem 0;
      margin: 4rem 0 0 0;
    }

    .cta-content {
      text-align: center;
    }

    .cta-content h2 {
      color: #ffffff;
      margin-bottom: 1rem;
    }

    .cta-content p {
      color: #e0f2fe;
      font-size: 1.1rem;
      margin-bottom: 2rem;
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .cta-content .btn-primary {
      background-color: #ffffff;
      color: #10b981;
    }

    .cta-content .btn-primary:hover {
      background-color: #f0f9ff;
    }

    @media (max-width: 768px) {
      .hero {
        padding: 3rem 0;
        margin-bottom: 2rem;
      }

      .hero .container {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .hero-content h1 {
        font-size: 2rem;
      }

      .hero-subtitle {
        font-size: 1rem;
      }

      .hero-cta {
        flex-direction: column;
      }

      .featured-grid,
      .articles-grid,
      .categories-grid {
        grid-template-columns: 1fr;
      }

      .featured-section,
      .categories-section,
      .latest-section {
        padding: 2rem 0;
      }
    }
  </style>
</BaseLayout>
