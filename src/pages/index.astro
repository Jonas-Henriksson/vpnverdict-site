---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../site.config';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const latestArticles = [...allArticles]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const TOP_PICKS = [
  { name: 'NordVPN', price: '$3.39/mo', category: 'Best Overall', slug: 'nordvpn', tag: "Editor's Pick" },
  { name: 'ProtonVPN', price: '$4.99/mo', category: 'Best Privacy', slug: 'protonvpn', tag: 'No-logs Verified' },
  { name: 'Surfshark', price: '$2.49/mo', category: 'Best Value', slug: 'surfshark-vpn', tag: 'Best Value' },
  { name: 'ExpressVPN', price: '$6.67/mo', category: 'Fastest Speed', slug: 'expressvpn', tag: 'Speed Leader' },
  { name: 'CyberGhost', price: '$2.19/mo', category: 'Best for Streaming', slug: 'cyberghost', tag: 'Stream-Ready' },
];

const featuredArticle = sortedArticles[0];
const rankedArticles  = sortedArticles.slice(1, 7);
const remainingArticles = sortedArticles.slice(7);

const API_URL = 'https://newsletter.vpnverdict.net/subscribe';
const SITE_ID = 'vpnverdict';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'VPNVerdict',
  'url': 'https://vpnverdict.net',
  'description': siteConfig.description,
};
---

<BaseLayout
  title={`${siteConfig.siteName} — ${siteConfig.tagline}`}
  description={siteConfig.description}
  structuredData={structuredData}
>
  <!-- ── 3-column layout ──────────────────────────── -->
  <div class="three-col-wrap">

    <!-- LEFT: Latest Reviews -->
    <aside class="col-left">
      <div class="panel-header">
        <span class="panel-label">Latest reviews</span>
      </div>
      <ul class="latest-list">
        {latestArticles.map((a) => (
          <li class="latest-item">
            <a href={`/${a.slug}`} class="latest-link">
              {a.data.category && (
                <span class="latest-cat">{a.data.category}</span>
              )}
              <span class="latest-title">{a.data.title}</span>
              <time class="latest-date" datetime={new Date(a.data.date).toISOString()}>
                {new Date(a.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
      {allArticles.length > 8 && (
        <a href="/reviews" class="see-all-link">All reviews &rarr;</a>
      )}
    </aside>

    <!-- CENTER: Featured hero + subscribe strip + rankings -->
    <main class="col-center">

      <!-- Featured hero -->
      {featuredArticle && (
        <section class="featured-hero">
          <a href={`/${featuredArticle.slug}`} class="hero-card">
            <div class="hero-card-top">
              <div class="hero-rank">#1</div>
              <div class="hero-badges">
                {featuredArticle.data.category && (
                  <span class="hero-cat">{featuredArticle.data.category}</span>
                )}
                {featuredArticle.data.badge && (
                  <span class:list={['hero-badge', `hero-badge--${featuredArticle.data.badge}`]}>
                    {featuredArticle.data.badge === 'editors-pick' ? "Editor's Pick" :
                     featuredArticle.data.badge === 'top-rated' ? 'Top Rated' :
                     featuredArticle.data.badge === 'best-value' ? 'Best Value' : 'Tested'}
                  </span>
                )}
              </div>
              {featuredArticle.data.score && (
                <div class="hero-score">
                  <span class="hero-score-val">{featuredArticle.data.score.toFixed(1)}</span>
                  <span class="hero-score-max">/10</span>
                </div>
              )}
            </div>
            <h2 class="hero-title">{featuredArticle.data.title}</h2>
            <p class="hero-desc">{featuredArticle.data.description}</p>
            <div class="hero-meta">
              <time datetime={new Date(featuredArticle.data.date).toISOString()}>
                {new Date(featuredArticle.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              {featuredArticle.data.winner && (
                <span class="hero-winner">Winner: <strong>{featuredArticle.data.winner}</strong></span>
              )}
              <span class="hero-read">Read review &rarr;</span>
            </div>
            <div class="hero-accent"></div>
          </a>
        </section>
      )}

      <!-- Subscribe strip -->
      <div class="subscribe-strip" id="subscribe-strip">
        <div class="subscribe-copy">
          <span class="subscribe-icon">&#128274;</span>
          <span class="subscribe-text">Privacy-first VPN picks, tested on real connections. No fluff.</span>
        </div>
        <form class="subscribe-form" id="subscribe-form" novalidate>
          <input
            type="email"
            class="subscribe-input"
            placeholder="your@email.com"
            required
            autocomplete="email"
            id="subscribe-email"
          />
          <button type="submit" class="subscribe-btn">Subscribe</button>
        </form>
        <p class="subscribe-success" id="subscribe-success" aria-live="polite"></p>
      </div>

      <!-- Rankings grid -->
      {rankedArticles.length > 0 && (
        <section class="rankings">
          <div class="section-header">
            <span class="section-label">Rankings</span>
            <div class="section-line"></div>
          </div>
          <div class="rankings-grid">
            {rankedArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                  rank={i + 2}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- More Reviews -->
      {remainingArticles.length > 0 && (
        <section class="more-reviews">
          <div class="section-header">
            <span class="section-label">More Reviews</span>
            <div class="section-line"></div>
          </div>
          <div class="more-grid">
            {remainingArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Methodology CTA -->
      <section class="methodology-cta">
        <div class="methodology-inner">
          <span class="methodology-label">Our Promise</span>
          <h2>Every VPN tested on our actual connections.<br/><em>Speed, kill switch, DNS leak — all verified hands-on.</em></h2>
          <p>
            We test every VPN on real hardware before publishing a score. Affiliate commissions fund
            our work but never influence rankings. Providers cannot pay for placement.
          </p>
          <a href="/disclosure" class="methodology-link">Read our full methodology &rarr;</a>
        </div>
      </section>

    </main>

    <!-- RIGHT: Sticky VPN picks -->
    <aside class="col-right">
      <div class="panel-header">
        <span class="panel-label">Top VPN picks</span>
      </div>
      <ul class="picks-list">
        {TOP_PICKS.map((pick) => (
          <li class="pick-item">
            <a href={`/go/${pick.slug}`} class="pick-link" target="_blank" rel="nofollow noopener">
              <div class="pick-top">
                <span class="pick-name">{pick.name}</span>
                {pick.tag && <span class="pick-tag">{pick.tag}</span>}
              </div>
              <div class="pick-meta">
                <span class="pick-cat">{pick.category}</span>
                <span class="pick-price">{pick.price}</span>
              </div>
              <span class="pick-cta">Get deal &rarr;</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="picks-disclosure">Affiliate links. Commissions never influence rankings.</p>
    </aside>

  </div><!-- /.three-col-wrap -->
</BaseLayout>

<script define:vars={{ API_URL, SITE_ID }}>
  const form = document.getElementById('subscribe-form');
  const emailInput = document.getElementById('subscribe-email');
  const successEl = document.getElementById('subscribe-success');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput?.value?.trim();
      if (!email) return;

      const btn = form.querySelector('button');
      if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }

      try {
        const res = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, site_id: SITE_ID }),
        });
        if (res.ok) {
          form.style.display = 'none';
          if (successEl) {
            successEl.textContent = 'You\'re in. Check your inbox.';
            successEl.classList.add('show');
          }
        } else {
          if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
          if (successEl) {
            successEl.textContent = 'Something went wrong — try again.';
            successEl.classList.add('show', 'error');
          }
        }
      } catch {
        if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; }
        if (successEl) {
          successEl.textContent = 'Network error — please try again.';
          successEl.classList.add('show', 'error');
        }
      }
    });
  }
</script>

<style>
  /* ── Three-column layout ─────────────────────────── */
  .three-col-wrap {
    display: grid;
    grid-template-columns: 220px 1fr 220px;
    grid-template-areas: "left center right";
    gap: var(--space-2xl);
    align-items: start;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-2xl) 0 var(--space-4xl);
  }

  .col-left  { grid-area: left; }
  .col-center { grid-area: center; min-width: 0; }
  .col-right { grid-area: right; position: sticky; top: var(--space-xl); }

  /* ── Shared panel header ─────────────────────────── */
  .panel-header {
    border-bottom: 2px solid var(--ink-950);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
  }

  .panel-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-950);
  }

  /* ── Left: Latest list ───────────────────────────── */
  .latest-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .latest-item + .latest-item {
    border-top: 1px solid var(--ink-100);
  }

  .latest-link {
    display: block;
    padding: var(--space-sm) 0;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .latest-link:hover .latest-title { color: var(--electric); }

  .latest-cat {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--electric);
    margin-bottom: 2px;
  }

  .latest-title {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-950);
    line-height: 1.35;
    margin-bottom: 3px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .latest-date {
    display: block;
    font-size: 0.7rem;
    color: var(--ink-400);
  }

  .see-all-link {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--electric);
    text-decoration: none;
  }

  .see-all-link:hover { opacity: 0.75; }

  /* ── Center: Featured hero ───────────────────────── */
  .featured-hero { margin-bottom: var(--space-xl); }

  .hero-card {
    display: block;
    position: relative;
    background: var(--surface-inverse);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    color: white;
    overflow: hidden;
    padding: var(--space-xl) var(--space-2xl);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .hero-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
    color: white;
  }

  .hero-card-top {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .hero-rank {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink-600);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .hero-card:hover .hero-rank { color: var(--electric); }

  .hero-badges {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex: 1;
  }

  .hero-cat {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-400);
  }

  .hero-badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .hero-badge--editors-pick { background: rgba(217, 119, 6, 0.2); color: #fbbf24; }
  .hero-badge--top-rated    { background: rgba(14, 165, 233, 0.2); color: #7dd3fc; }
  .hero-badge--best-value   { background: rgba(5, 150, 105, 0.2); color: #6ee7b7; }
  .hero-badge--tested       { background: rgba(255,255,255,0.08); color: var(--ink-400); }

  .hero-score {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-left: auto;
  }

  .hero-score-val {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: white;
  }

  .hero-score-max {
    font-size: 0.9rem;
    color: var(--ink-500);
    margin-bottom: 0.25rem;
  }

  .hero-title {
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    color: white;
    margin: 0 0 var(--space-sm);
    line-height: 1.2;
  }

  .hero-desc {
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--ink-400);
    margin-bottom: var(--space-md);
    max-width: 520px;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    font-size: 0.78rem;
    color: var(--ink-500);
    flex-wrap: wrap;
  }

  .hero-winner { color: var(--ink-400); }
  .hero-winner strong { color: white; font-weight: 600; }

  .hero-read { color: var(--electric); font-weight: 500; margin-left: auto; }

  .hero-accent {
    position: absolute;
    top: 0; right: 0;
    width: 35%;
    height: 100%;
    background: linear-gradient(135deg, transparent 0%, rgba(14, 165, 233, 0.05) 50%, rgba(14, 165, 233, 0.12) 100%);
    pointer-events: none;
  }

  /* ── Center: Subscribe strip ─────────────────────── */
  .subscribe-strip {
    background: var(--ink-50);
    border: 1px solid var(--ink-200);
    border-left: 3px solid var(--electric);
    border-radius: var(--border-radius);
    padding: var(--space-md) var(--space-lg);
    margin-bottom: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .subscribe-copy {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .subscribe-icon { font-size: 1rem; flex-shrink: 0; }

  .subscribe-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-700);
    line-height: 1.4;
  }

  .subscribe-form {
    display: flex;
    gap: var(--space-sm);
  }

  .subscribe-input {
    flex: 1;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--ink-300);
    border-radius: var(--border-radius-sm);
    font-size: 0.875rem;
    font-family: var(--font-body);
    color: var(--ink-900);
    background: white;
    transition: border-color var(--duration-fast) var(--ease-out);
    min-width: 0;
  }

  .subscribe-input:focus {
    outline: none;
    border-color: var(--electric);
    box-shadow: 0 0 0 2px rgba(14, 165, 233, 0.15);
  }

  .subscribe-btn {
    padding: 0.5rem 1.125rem;
    background: var(--electric);
    color: white;
    border: none;
    border-radius: var(--border-radius-sm);
    font-size: 0.875rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .subscribe-btn:hover:not(:disabled) { opacity: 0.85; }
  .subscribe-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .subscribe-success {
    display: none;
    font-size: 0.825rem;
    font-weight: 600;
    color: #059669;
    margin: 0;
  }

  .subscribe-success.show { display: block; }
  .subscribe-success.error { color: #dc2626; }

  /* ── Center: Section headers ─────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
    white-space: nowrap;
  }

  .section-line { flex: 1; height: 1px; background: var(--ink-100); }

  /* ── Center: Rankings grid ───────────────────────── */
  .rankings { margin-bottom: var(--space-3xl); }

  .rankings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .article-animate { animation: fadeInUp var(--duration-slow) var(--ease-out) both; }

  /* ── Center: More reviews ────────────────────────── */
  .more-reviews { margin-bottom: var(--space-3xl); }

  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  /* ── Center: Methodology CTA ─────────────────────── */
  .methodology-cta { margin: var(--space-3xl) 0 0; }

  .methodology-inner {
    padding: var(--space-2xl) 0;
    border-top: 2px solid var(--ink-950);
  }

  .methodology-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
  }

  .methodology-inner h2 {
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.25;
  }

  .methodology-inner h2 em { font-style: italic; color: var(--ink-500); }

  .methodology-inner p { color: var(--ink-500); max-width: 540px; line-height: 1.7; font-size: 0.9rem; }

  .methodology-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink-950);
    text-decoration: none;
    border-bottom: 1.5px solid var(--ink-950);
    padding-bottom: 2px;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .methodology-link:hover { opacity: 0.7; color: var(--ink-950); }

  /* ── Right: VPN picks ────────────────────────────── */
  .picks-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-sm);
  }

  .pick-item + .pick-item {
    border-top: 1px solid var(--ink-100);
  }

  .pick-link {
    display: block;
    padding: var(--space-sm) 0;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .pick-link:hover .pick-name { color: var(--electric); }

  .pick-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.25rem;
    margin-bottom: 3px;
  }

  .pick-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ink-950);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .pick-tag {
    font-size: 0.55rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: rgba(14, 165, 233, 0.12);
    color: var(--electric);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pick-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 4px;
  }

  .pick-cat {
    font-size: 0.7rem;
    color: var(--ink-500);
  }

  .pick-price {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink-700);
  }

  .pick-cta {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--electric);
  }

  .picks-disclosure {
    font-size: 0.65rem;
    color: var(--ink-400);
    margin: 0;
    line-height: 1.4;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1100px) {
    .three-col-wrap {
      grid-template-columns: 200px 1fr;
      grid-template-areas:
        "left center"
        "right center";
    }

    .col-right {
      position: static;
      grid-area: right;
    }
  }

  @media (max-width: 768px) {
    .three-col-wrap {
      grid-template-columns: 1fr;
      grid-template-areas:
        "center"
        "left"
        "right";
      gap: var(--space-xl);
      padding: var(--space-xl) 0 var(--space-3xl);
    }

    .col-right { position: static; }

    .hero-card { padding: var(--space-lg); }
    .hero-title { font-size: clamp(1.25rem, 5vw, 1.75rem); }
    .hero-card-top { flex-wrap: wrap; }
    .hero-accent { display: none; }

    .subscribe-form { flex-direction: column; }
    .subscribe-btn { width: 100%; }

    .rankings-grid, .more-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
