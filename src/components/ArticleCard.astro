---
export interface Props {
  title: string; description: string; date: Date; author?: string;
  category?: string; slug: string; score?: number; badge?: string; rank?: number;
}
const { title, description, date, author, category, slug, score, badge, rank } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const badgeLabels: Record<string, string> = {
  'editors-pick': "Editor's Pick",
  'best-value': 'Best Value',
  'top-rated': 'Top Rated',
  'tested': 'Tested',
};
const badgeLabel = badge ? badgeLabels[badge] || badge : null;
---

<article class:list={['card', { 'card--ranked': !!rank }]}>
  <a href={`/${slug}`} class="card-link">
    {rank && <span class="card-rank">#{rank}</span>}
    <div class="card-body">
      <div class="card-top">
        <div class="card-top-left">
          {category && <span class="card-category">{category}</span>}
          {badgeLabel && (
            <span class:list={['card-badge', `card-badge--${badge}`]}>
              {badge === 'editors-pick' && <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 0l1.5 3.1L10 3.6 7.5 6l.6 3.5L5 7.8 1.9 9.5l.6-3.5L0 3.6l3.5-.5L5 0z" fill="currentColor"/></svg>}
              {badgeLabel}
            </span>
          )}
        </div>
        {score && (
          <div class="card-score">
            <span class="card-score-value">{score.toFixed(1)}</span>
            <span class="card-score-max">/10</span>
          </div>
        )}
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
      <div class="card-footer">
        <time class="card-date">{formattedDate}</time>
        <span class="card-cta">Read review<svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="card-arrow"><path d="M1 7h12m0 0L8 2.5M13 7l-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    position: relative;
    border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg);
    background: var(--surface);
    transition: border-color var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
    height: 100%;
  }

  .card:hover {
    border-color: var(--ink-300);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-link {
    display: flex;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .card-rank {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 48px;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ink-200);
    border-right: 1px solid var(--ink-100);
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .card:hover .card-rank { color: var(--electric); }

  .card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
    min-width: 0;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .card-top-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .card-category {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
  }

  .card-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  .card-badge--editors-pick { background: var(--amber-light); color: var(--amber); }
  .card-badge--top-rated { background: var(--electric-light); color: var(--electric); }
  .card-badge--best-value { background: var(--emerald-light); color: var(--emerald); }
  .card-badge--tested { background: var(--ink-50); color: var(--ink-500); }

  .card-score {
    display: flex;
    align-items: baseline;
    gap: 1px;
    flex-shrink: 0;
  }

  .card-score-value {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink-950);
  }

  .card-score-max { font-size: 0.7rem; font-weight: 500; color: var(--ink-400); }

  .card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--ink-950);
    margin: 0 0 var(--space-sm) 0;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .card:hover .card-title { color: var(--electric); }

  .card-description {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--ink-500);
    margin: 0 0 var(--space-md) 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
  }

  .card-date { font-size: 0.75rem; color: var(--ink-400); font-weight: 500; }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-950);
  }

  .card-arrow { transition: transform var(--duration-fast) var(--ease-out); }
  .card:hover .card-arrow { transform: translateX(3px); }

  @media (max-width: 640px) {
    .card-body { padding: var(--space-md); }
    .card-title { font-size: 1.05rem; }
    .card-rank { min-width: 36px; font-size: 1.25rem; }
    .card-score-value { font-size: 1.25rem; }
  }
</style>
