---
export interface Props {
  name: string;
  slug: string;
  title: string;
  niche: string;
  yearsExperience: number;
  initials?: string;
  image?: string;
  bio?: string;
  credentials?: string;
}

const { name, slug, title, niche, yearsExperience, initials, image, bio, credentials } = Astro.props;
const displayInitials = initials || name.split(' ').map((n: string) => n[0]).join('');

// Truncate bio to first 2 sentences for the card
function twoSentences(text: string): string {
  if (!text) return '';
  const matches = text.match(/[^.!?]+[.!?]+/g) || [];
  return matches.slice(0, 2).join(' ').trim();
}
const shortBio = bio ? twoSentences(bio) : '';
---

<div class="author-bio">
  <a href={`/author/${slug}`} class="author-avatar" aria-label={`Read more about ${name}`}>
    {image ? (
      <img
        src={image}
        alt={name}
        width="44"
        height="44"
        class="avatar-img"
        loading="lazy"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <span class="avatar-initials" style="display:none">{displayInitials}</span>
    ) : (
      <span class="avatar-initials">{displayInitials}</span>
    )}
  </a>
  <div class="author-info">
    <div class="author-name-row">
      <a href={`/author/${slug}`} class="author-name">{name}</a>
      <a href="/how-we-test" class="how-we-test-link">
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1v8M4 6l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        How We Test
      </a>
    </div>
    <span class="author-title">{title} · {yearsExperience} years testing {niche}</span>
    {shortBio && <p class="author-bio-text">{shortBio}</p>}
    {credentials && <span class="author-credentials">{credentials}</span>}
  </div>
</div>

<style>
  .author-bio {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1.1rem 1.1rem 1rem;
    background: var(--surface-raised, #f8f9fa);
    border: 1px solid var(--ink-100, #e5e7eb);
    border-radius: var(--border-radius-lg, 10px);
    margin-bottom: var(--space-lg, 1.5rem);
  }

  .author-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--ink-950, #111);
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    flex-shrink: 0;
    transition: transform 0.15s ease-out;
    overflow: hidden;
    border: 2px solid var(--ink-100, #e5e7eb);
  }
  .author-avatar:hover { transform: scale(1.04); }

  .avatar-img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .avatar-initials {
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
    flex: 1;
  }

  .author-name-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .author-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--ink-950, #111);
    text-decoration: none;
    line-height: 1.2;
  }
  .author-name:hover { text-decoration: underline; text-underline-offset: 2px; }

  .author-title {
    font-size: 0.75rem;
    color: var(--ink-500, #6b7280);
    line-height: 1.3;
  }

  .author-bio-text {
    font-size: 0.82rem;
    line-height: 1.55;
    color: var(--ink-700, #374151);
    margin: 0.2rem 0 0;
  }

  .author-credentials {
    font-size: 0.7rem;
    color: var(--ink-400, #9ca3af);
    line-height: 1.3;
    font-style: italic;
  }

  .how-we-test-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--ink-500, #6b7280);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--ink-200, #d1d5db);
    border-radius: 5px;
    transition: all 0.15s ease-out;
    flex-shrink: 0;
  }
  .how-we-test-link:hover {
    color: var(--ink-950, #111);
    border-color: var(--ink-950, #111);
    background: var(--surface, #fff);
  }

  @media (max-width: 640px) {
    .author-bio { gap: 0.65rem; }
    .author-avatar { width: 48px; height: 48px; }
    .avatar-img { width: 48px; height: 48px; }
  }
  @media (prefers-color-scheme: dark) {
    .author-bio { background: #111318 !important; border-color: #1c1c21 !important; }
    .author-avatar { background: #0a0a0b !important; border-color: #1c1c21 !important; }
    .author-bio-text { color: #c9cad6 !important; }
  }
</style>
