---
export interface Props {
  score?: number;
  verdict?: string;
  winner?: string;
  badge?: string;
}
const { score, verdict, winner, badge } = Astro.props;
const hasContent = score || verdict || winner;

const badgeLabels: Record<string, string> = {
  'editors-pick': "Editor's Pick",
  'best-value': 'Best Value',
  'top-rated': 'Top Rated',
  'tested': 'Independently Tested',
};
const badgeLabel = badge ? badgeLabels[badge] || badge : null;
---

{hasContent && (
  <div class="verdict-banner">
    <div class="verdict-inner">
      <div class="verdict-main">
        {badgeLabel && (
          <span class:list={['verdict-badge', `verdict-badge--${badge}`]}>
            {badge === 'editors-pick' && <svg width="12" height="12" viewBox="0 0 10 10" fill="none"><path d="M5 0l1.5 3.1L10 3.6 7.5 6l.6 3.5L5 7.8 1.9 9.5l.6-3.5L0 3.6l3.5-.5L5 0z" fill="currentColor"/></svg>}
            {badgeLabel}
          </span>
        )}
        {verdict && <p class="verdict-text">{verdict}</p>}
        {winner && (
          <div class="verdict-winner">
            <span class="verdict-winner-label">Winner</span>
            <span class="verdict-winner-name">{winner}</span>
          </div>
        )}
      </div>
      {score && (
        <div class="verdict-score">
          <span class="verdict-score-value">{score.toFixed(1)}</span>
          <div class="verdict-score-meta">
            <span class="verdict-score-max">/ 10</span>
            <span class="verdict-score-label">Overall</span>
          </div>
          <div class="verdict-score-ring">
            <svg viewBox="0 0 36 36" class="verdict-ring-svg">
              <path class="verdict-ring-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
              <path class="verdict-ring-fill" stroke-dasharray={`${score * 10}, 100`} d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
            </svg>
          </div>
        </div>
      )}
    </div>
  </div>
)}

<style>
  .verdict-banner {
    background: var(--ink-950);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl) var(--space-2xl);
    margin-bottom: var(--space-2xl);
    color: white;
    position: relative;
    overflow: hidden;
  }

  .verdict-banner::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 200px;
    height: 100%;
    background: linear-gradient(135deg, transparent 0%, rgba(14, 165, 233, 0.06) 50%, rgba(14, 165, 233, 0.12) 100%);
    pointer-events: none;
  }

  .verdict-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    position: relative;
    z-index: 1;
  }

  .verdict-main {
    flex: 1;
    min-width: 0;
  }

  .verdict-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.625rem;
    border-radius: 3px;
    margin-bottom: var(--space-sm);
  }

  .verdict-badge--editors-pick { background: rgba(217, 119, 6, 0.2); color: #fbbf24; }
  .verdict-badge--top-rated { background: rgba(14, 165, 233, 0.2); color: #7dd3fc; }
  .verdict-badge--best-value { background: rgba(5, 150, 105, 0.2); color: #6ee7b7; }
  .verdict-badge--tested { background: rgba(255, 255, 255, 0.08); color: var(--ink-400); }

  .verdict-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.4;
    color: var(--ink-200);
    margin: 0 0 var(--space-md) 0;
    max-width: 480px;
  }

  .verdict-winner {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .verdict-winner-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-500);
  }

  .verdict-winner-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    color: white;
    letter-spacing: -0.01em;
  }

  .verdict-score {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .verdict-score-value {
    font-family: var(--font-display);
    font-size: 3.5rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: white;
  }

  .verdict-score-meta {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .verdict-score-max { font-size: 0.9rem; font-weight: 500; color: var(--ink-400); }
  .verdict-score-label { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ink-500); }

  .verdict-score-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    opacity: 0.12;
    pointer-events: none;
  }

  .verdict-ring-svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .verdict-ring-bg { fill: none; stroke: white; stroke-width: 2; opacity: 0.2; }
  .verdict-ring-fill { fill: none; stroke: var(--electric); stroke-width: 2; stroke-linecap: round; }

  @media (max-width: 640px) {
    .verdict-banner { padding: var(--space-lg); }
    .verdict-inner { flex-direction: column; align-items: flex-start; gap: var(--space-md); }
    .verdict-score-value { font-size: 2.5rem; }
    .verdict-score-ring { display: none; }
  }
</style>
