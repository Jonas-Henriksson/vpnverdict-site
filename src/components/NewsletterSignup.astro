---
interface Props {
  variant?: 'sidebar' | 'inline' | 'hero';
}

const { variant = 'inline' } = Astro.props;
const API_URL = 'http://37.27.215.124:8485/subscribe';
const SITE_ID = 'vpnverdict';
---

<div class={`newsletter newsletter--${variant}`} id="newsletter">
  <div class="newsletter__inner">
    {variant === 'hero' ? (
      <h2 class="newsletter__title">Stay Ahead on VPN Privacy</h2>
    ) : (
      <h3 class="newsletter__title">VPN News & Deals</h3>
    )}
    <p class="newsletter__desc">
      Get weekly VPN reviews, exclusive deals, and privacy tips. No spam, unsubscribe anytime.
    </p>
    <form class="newsletter__form" id="newsletter-form">
      <div class="newsletter__input-group">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
          class="newsletter__input"
          id="newsletter-email"
        />
        <button type="submit" class="newsletter__btn" id="newsletter-btn">
          Subscribe
        </button>
      </div>
      <p class="newsletter__status" id="newsletter-status"></p>
    </form>
    <p class="newsletter__privacy">We respect your privacy. Read our <a href="/privacy">privacy policy</a>.</p>
  </div>
</div>

<script define:vars={{ API_URL, SITE_ID }}>
  const form = document.getElementById('newsletter-form');
  const emailInput = document.getElementById('newsletter-email');
  const btn = document.getElementById('newsletter-btn');
  const status = document.getElementById('newsletter-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = 'Subscribing...';
    status.textContent = '';
    status.className = 'newsletter__status';

    try {
      const resp = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, site: SITE_ID }),
      });
      const data = await resp.json();
      if (resp.ok) {
        status.textContent = 'You\'re in! Check your inbox.';
        status.className = 'newsletter__status newsletter__status--success';
        emailInput.value = '';
      } else {
        status.textContent = data.error || 'Something went wrong.';
        status.className = 'newsletter__status newsletter__status--error';
      }
    } catch {
      status.textContent = 'Connection error. Try again.';
      status.className = 'newsletter__status newsletter__status--error';
    }

    btn.disabled = false;
    btn.textContent = 'Subscribe';
  });
</script>

<style>
  .newsletter {
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .newsletter--sidebar {
    background: linear-gradient(135deg, #0f1419 0%, #1a1f2b 100%);
    border: 1px solid #2d3748;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .newsletter--inline {
    background: linear-gradient(135deg, #0a0e13 0%, #1a1f2b 100%);
    border: 1px solid #10b981;
    padding: 2.5rem;
    margin: 3rem 0;
    text-align: center;
  }

  .newsletter--hero {
    background: linear-gradient(135deg, #064e3b 0%, #0f1419 60%, #1a1f2b 100%);
    border: 1px solid #10b981;
    padding: 3rem;
    margin: 3rem 0;
    text-align: center;
  }

  .newsletter__title {
    color: #ffffff;
    margin: 0 0 0.5rem 0;
    font-weight: 700;
  }

  .newsletter--sidebar .newsletter__title {
    font-size: 1.1rem;
  }

  .newsletter--inline .newsletter__title,
  .newsletter--hero .newsletter__title {
    font-size: 1.5rem;
  }

  .newsletter__desc {
    color: #a8b3bf;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .newsletter__input-group {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter--sidebar .newsletter__input-group {
    flex-direction: column;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid #2d3748;
    border-radius: 0.375rem;
    background-color: #0f1419;
    color: #e4e9f0;
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .newsletter__input:focus {
    border-color: #10b981;
  }

  .newsletter__input::placeholder {
    color: #6b7280;
  }

  .newsletter__btn {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    color: #ffffff;
    border: none;
    border-radius: 0.375rem;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    font-family: inherit;
  }

  .newsletter__btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
  }

  .newsletter__btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .newsletter__status {
    font-size: 0.85rem;
    margin-top: 0.75rem;
    min-height: 1.2em;
  }

  .newsletter__status--success {
    color: #10b981;
  }

  .newsletter__status--error {
    color: #ef4444;
  }

  .newsletter__privacy {
    font-size: 0.75rem;
    color: #6b7280;
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  .newsletter__privacy a {
    color: #6b7280;
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .newsletter--inline .newsletter__input-group,
    .newsletter--hero .newsletter__input-group {
      flex-direction: column;
    }

    .newsletter--inline,
    .newsletter--hero {
      padding: 2rem 1.5rem;
    }
  }
</style>
