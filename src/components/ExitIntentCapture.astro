---
interface Props {
  siteId: string;
  siteName: string;
  niche: string;
}
const { siteId, siteName, niche } = Astro.props;
const API_URL = '/api/subscribe';

const nicheHooks: Record<string, string> = {
  'ai-tools': 'Get our weekly AI tool picks before anyone else.',
  'vpn': 'Get our VPN speed test results + exclusive deals.',
  'sleep-mattress': 'Get our sleep score cheat sheet + exclusive mattress deals.',
  'outdoor-hiking': 'Get our gear loadout guides + trail-tested deals.',
  'pet-care': 'Get our vet-approved product picks + exclusive deals.',
  'home-security': 'Get our security system scorecards + exclusive deals.',
  'solar-energy': 'Get our solar savings calculator + installer deals.',
  'electric-vehicles': 'Get our EV comparison sheets + charging deals.',
  'web-hosting': 'Get our hosting benchmark data + exclusive discounts.',
  'small-business-software': 'Get our software stack guides + exclusive trials.',
};
const hookText = nicheHooks[niche] || 'Get our top picks delivered weekly.';
---

<!-- Exit-Intent Slide-Up Bar -->
<div class="exit-capture" id="exit-capture" aria-hidden="true">
  <div class="exit-capture-inner">
    <button class="exit-capture-close" id="exit-capture-close" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
    <div class="exit-capture-content">
      <div class="exit-capture-text">
        <span class="exit-capture-badge">Before you go</span>
        <p class="exit-capture-hook">{hookText}</p>
      </div>
      <form class="exit-capture-form" id="exit-capture-form">
        <input
          type="email"
          name="email"
          placeholder="you@email.com"
          required
          autocomplete="email"
          class="exit-capture-input"
          id="exit-capture-email"
        />
        <button type="submit" class="exit-capture-btn" id="exit-capture-btn">
          Send me the picks
        </button>
      </form>
      <p class="exit-capture-status" id="exit-capture-status"></p>
    </div>
  </div>
</div>

<script define:vars={{ API_URL, siteId }}>
  (function() {
    const KEY = 'exit_capture_shown_' + siteId;
    const el = document.getElementById('exit-capture');
    const form = document.getElementById('exit-capture-form');
    const emailInput = document.getElementById('exit-capture-email');
    const btn = document.getElementById('exit-capture-btn');
    const status = document.getElementById('exit-capture-status');
    const closeBtn = document.getElementById('exit-capture-close');

    // Don't show if already shown this session
    if (sessionStorage.getItem(KEY)) return;

    let triggered = false;

    function showCapture() {
      if (triggered) return;
      triggered = true;
      sessionStorage.setItem(KEY, '1');
      el.classList.add('exit-capture--visible');
      el.setAttribute('aria-hidden', 'false');
    }

    // Exit intent: mouse leaves viewport top
    document.addEventListener('mouseout', function(e) {
      if (e.clientY <= 0) showCapture();
    });

    // Mobile fallback: show after 60s of reading
    setTimeout(function() {
      if (window.innerWidth <= 768) showCapture();
    }, 60000);

    // Also show after scrolling 70% of page
    let scrollTriggered = false;
    window.addEventListener('scroll', function() {
      if (scrollTriggered) return;
      const scrollPercent = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      if (scrollPercent > 0.7) {
        scrollTriggered = true;
        setTimeout(showCapture, 2000);
      }
    });

    // Close
    closeBtn.addEventListener('click', function() {
      el.classList.remove('exit-capture--visible');
      el.setAttribute('aria-hidden', 'true');
    });

    // Submit
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      btn.disabled = true;
      btn.textContent = 'Subscribing...';
      status.textContent = '';
      status.className = 'exit-capture-status';

      try {
        const resp = await fetch(API_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, site: siteId, source: 'exit-intent' }),
        });
        const data = await resp.json();
        if (resp.ok) {
          status.textContent = "You're in! Check your inbox.";
          status.className = 'exit-capture-status exit-capture-status--success';
          emailInput.value = '';
          setTimeout(function() {
            el.classList.remove('exit-capture--visible');
          }, 3000);
        } else {
          status.textContent = data.error || 'Something went wrong.';
          status.className = 'exit-capture-status exit-capture-status--error';
        }
      } catch(err) {
        status.textContent = 'Connection error. Try again.';
        status.className = 'exit-capture-status exit-capture-status--error';
      }

      btn.disabled = false;
      btn.textContent = 'Send me the picks';
    });
  })();
</script>

<style>
  .exit-capture {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .exit-capture--visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  .exit-capture-inner {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    border-top: 2px solid #f59e0b;
    padding: 1.25rem 1.5rem;
    position: relative;
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.3);
  }

  .exit-capture-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: none;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 4px;
    line-height: 1;
    transition: color 0.15s;
  }

  .exit-capture-close:hover {
    color: #f8fafc;
  }

  .exit-capture-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .exit-capture-text {
    margin-bottom: 0.75rem;
  }

  .exit-capture-badge {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #fbbf24;
    display: block;
    margin-bottom: 0.35rem;
  }

  .exit-capture-hook {
    font-size: 1rem;
    font-weight: 500;
    color: #f1f5f9;
    margin: 0;
    line-height: 1.4;
  }

  .exit-capture-form {
    display: flex;
    gap: 0.5rem;
  }

  .exit-capture-input {
    flex: 1;
    padding: 0.6rem 0.875rem;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.06);
    color: #f1f5f9;
    font-size: 0.875rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
    max-width: 280px;
  }

  .exit-capture-input::placeholder {
    color: #64748b;
  }

  .exit-capture-input:focus {
    border-color: #fbbf24;
  }

  .exit-capture-btn {
    padding: 0.6rem 1.25rem;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    color: #0f172a;
    border: none;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .exit-capture-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 12px rgba(245, 158, 11, 0.3);
  }

  .exit-capture-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .exit-capture-status {
    font-size: 0.75rem;
    margin-top: 0.4rem;
    min-height: 1em;
  }

  .exit-capture-status--success { color: #6ee7b7; }
  .exit-capture-status--error { color: #fca5a5; }

  @media (max-width: 640px) {
    .exit-capture-inner {
      padding: 1rem 1.25rem;
    }

    .exit-capture-form {
      flex-direction: column;
    }

    .exit-capture-input {
      max-width: none;
    }

    .exit-capture-hook {
      font-size: 0.9rem;
    }
  }
  @media (prefers-color-scheme: dark) {
    .newsletter--inline, .lead-magnet, .exit-overlay .exit-modal {
      background: #0a0a0b !important;
      color: white;
    }
  }
</style>
