---
// StickyBottomBuyBar — fixed 56px conversion safety net at the bottom of
// the viewport. The Wirecutter mobile pattern adopted as the empire-wide
// secondary CTA (the primary is the InlineOurPick box at the top of the
// prose).
//
// Behavior:
//   - Hidden by default
//   - Appears when the user scrolls past the InlineOurPick (so they've
//     already seen the recommendation in context first)
//   - Hides when the article footer (newsletter or related grid) enters
//     the viewport, so it doesn't compete with the bottom CTA
//   - Dismissable: a small × button hides it for the rest of the session
//     via sessionStorage
//
// The bar reads its content from data attributes on the InlineOurPick
// (rendered earlier in the page) so we don't duplicate the affiliate
// resolution logic.
---

<aside class="sbb" data-sbb hidden aria-label="Top pick affiliate">
  <div class="sbb-inner">
    <div class="sbb-tile" data-sbb-tile aria-hidden="true">
      <span data-sbb-initial></span>
    </div>
    <div class="sbb-text">
      <span class="sbb-label" data-sbb-label></span>
      <span class="sbb-name" data-sbb-name></span>
    </div>
    <div class="sbb-score" data-sbb-score-wrap>
      <span data-sbb-score></span>
      <span class="sbb-score-max">/10</span>
    </div>
    <a class="sbb-cta" data-sbb-cta href="#" rel="sponsored noopener" target="_blank">
      <span data-sbb-cta-text>Visit</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
    <button class="sbb-close" data-sbb-close aria-label="Dismiss" type="button">×</button>
  </div>
</aside>

<script>
  (() => {
    const bar = document.querySelector('[data-sbb]') as HTMLElement | null;
    const mark = document.querySelector('[data-iop-mark]') as HTMLElement | null;
    if (!bar || !mark) return;

    // Read the editor's pick data from the InlineOurPick markers
    const name = mark.dataset.iopName || '';
    const score = mark.dataset.iopScore || '';
    const href = mark.dataset.iopHref || '';
    const badge = mark.dataset.iopBadge || 'Top Pick';

    if (!name || !href) {
      // No affiliate match → never show the buy bar (graceful degradation)
      bar.remove();
      return;
    }

    // Session-dismiss: if the user hid this bar this session, never show it
    const DISMISS_KEY = 'sbb-dismissed';
    if (sessionStorage.getItem(DISMISS_KEY) === '1') {
      bar.remove();
      return;
    }

    // Hydrate the bar
    const initial = name.trim().charAt(0).toUpperCase();
    (bar.querySelector('[data-sbb-initial]') as HTMLElement).textContent = initial;
    (bar.querySelector('[data-sbb-label]') as HTMLElement).textContent = badge;
    (bar.querySelector('[data-sbb-name]') as HTMLElement).textContent = name;
    if (score) {
      (bar.querySelector('[data-sbb-score]') as HTMLElement).textContent = score;
    } else {
      (bar.querySelector('[data-sbb-score-wrap]') as HTMLElement).style.display = 'none';
    }
    const ctaLink = bar.querySelector('[data-sbb-cta]') as HTMLAnchorElement;
    ctaLink.href = href;
    (bar.querySelector('[data-sbb-cta-text]') as HTMLElement).textContent = `Visit ${name.length > 14 ? name.slice(0, 13) + '…' : name}`;

    // Dismiss
    const closeBtn = bar.querySelector('[data-sbb-close]') as HTMLButtonElement;
    closeBtn.addEventListener('click', () => {
      sessionStorage.setItem(DISMISS_KEY, '1');
      bar.classList.remove('sbb-show');
      setTimeout(() => bar.remove(), 200);
    });

    // Show only after the InlineOurPick has scrolled out of view (user has
    // seen the recommendation in its full context)
    let pickPassed = false;
    const pickObs = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting && e.boundingClientRect.top < 0) {
          pickPassed = true;
        } else if (e.isIntersecting) {
          pickPassed = false;
          bar.classList.remove('sbb-show');
          bar.hidden = true;
        }
        sync();
      }
    }, { rootMargin: '0px' });
    pickObs.observe(mark);

    // Hide near footer (avoid competing with the bottom section)
    let nearFooter = false;
    const footer = document.querySelector('footer');
    if (footer) {
      const footObs = new IntersectionObserver((entries) => {
        for (const e of entries) {
          nearFooter = e.isIntersecting;
          sync();
        }
      }, { rootMargin: '0px 0px -100px 0px' });
      footObs.observe(footer);
    }

    // Scroll-up-only: bar is the "re-engagement" CTA, not a persistent nag.
    // Show only when the user scrolls back UP (they've seen content, reconsidering).
    // Requires a 30px threshold to avoid firing on micro-adjustments.
    let scrollDir: 'up' | 'down' = 'down';
    let lastScrollY = window.scrollY;
    let scrollDelta = 0;
    window.addEventListener('scroll', () => {
      const dy = window.scrollY - lastScrollY;
      if (Math.sign(dy) !== Math.sign(scrollDelta)) scrollDelta = 0; // direction changed
      scrollDelta += dy;
      if (scrollDelta < -30) { scrollDir = 'up'; sync(); }
      else if (scrollDelta > 30) { scrollDir = 'down'; sync(); }
      lastScrollY = window.scrollY;
    }, { passive: true });

    function sync() {
      if (pickPassed && !nearFooter && scrollDir === 'up') {
        bar.hidden = false;
        requestAnimationFrame(() => bar.classList.add('sbb-show'));
      } else {
        bar.classList.remove('sbb-show');
      }
    }
  })();
</script>

<style>
  .sbb {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    background: var(--surface, #fff);
    border-top: 1px solid var(--ink-200, #e4e4e7);
    box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.06);
    transform: translateY(100%);
    transition: transform 0.25s ease;
  }
  .sbb.sbb-show { transform: translateY(0); }

  .sbb-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .sbb-tile {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 4px;
    background: var(--accent, var(--electric, var(--violet, #2563eb)));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--font-display, Georgia, serif);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
  }

  .sbb-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1 1 auto;
  }
  .sbb-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent, var(--electric, #2563eb));
    line-height: 1.1;
  }
  .sbb-name {
    font-family: var(--font-display, Georgia, serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink-950);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .sbb-score {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 0.1rem;
    font-family: var(--font-display, Georgia, serif);
  }
  .sbb-score [data-sbb-score] {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink-950);
  }
  .sbb-score-max {
    font-size: 0.65rem;
    color: var(--ink-400);
  }

  .sbb-cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.55rem 1rem;
    background: var(--accent, var(--electric, var(--violet, #2563eb)));
    color: #fff;
    text-decoration: none;
    border-radius: 5px;
    font-size: 0.8rem;
    font-weight: 600;
    transition: filter 0.15s ease;
  }
  .sbb-cta:hover { filter: brightness(0.92); }

  .sbb-close {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--ink-400);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    border-radius: 4px;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .sbb-close:hover {
    background: var(--ink-50);
    color: var(--ink-950);
  }

  @media (max-width: 640px) {
    .sbb-inner {
      padding: 0.55rem 0.75rem;
      gap: 0.6rem;
    }
    .sbb-tile { width: 32px; height: 32px; }
    .sbb-text { flex: 1 1 0; min-width: 0; }
    .sbb-name { font-size: 0.85rem; }
    .sbb-score { display: none; }  /* hide score on small to save horizontal space */
    .sbb-cta { padding: 0.5rem 0.75rem; font-size: 0.75rem; }
  }
</style>
