<aside class="product-banner">
  <p class="product-banner-label">AI Tools by Our Team</p>
  <div class="product-banner-grid">
    <a href="https://resume.toolsradar.net/scan" class="product-card" target="_blank" rel="noopener">
      <strong>AI Resume Scorer</strong>
      <span>Free scan — get your resume scored in 30 seconds</span>
    </a>
    <a href="https://contracts.toolsradar.net/review" class="product-card" target="_blank" rel="noopener">
      <strong>AI Contract Checker</strong>
      <span>Free review — analyze any contract for risks</span>
    </a>
    <a href="https://jonashenriksson.gumroad.com/l/ai-prompt-library" class="product-card" target="_blank" rel="noopener">
      <strong>200+ AI Prompts</strong>
      <span>$19 — copy-paste prompts for ChatGPT & Claude</span>
    </a>
  </div>
</aside>

<style>
  .product-banner {
    margin: 3rem 0 1rem;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(245, 184, 0, 0.08), rgba(13, 18, 41, 0.5));
    border: 1px solid rgba(245, 184, 0, 0.2);
    border-radius: 12px;
  }
  .product-banner-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f5b800;
    margin-bottom: 1rem;
  }
  .product-banner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.75rem;
  }
  .product-card {
    display: block;
    padding: 1rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .product-card:hover {
    border-color: rgba(245, 184, 0, 0.4);
  }
  .product-card strong {
    display: block;
    color: #ffffff;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }
  .product-card span {
    color: #8a8a9a;
    font-size: 0.8rem;
  }
</style>
