---
/**
 * EzoicAds.astro — Ezoic ad placeholder component for AI Empire sites
 *
 * Inserts Ezoic ad placeholders that get filled by Ezoic's JS runtime.
 * Uses IntersectionObserver for lazy loading so ads don't hurt CWV.
 * Dark-theme-aware: navy containers with subtle borders, no white flash.
 *
 * Kill switch: set EZOIC_ENABLED=false in .env to disable all ads.
 *
 * Placement types:
 *   - "after-h2"      — inline after the first H2 (mid-content, high RPM)
 *   - "mid-article"   — roughly 60% into content
 *   - "sidebar"       — sticky sidebar ad
 *   - "between-cards" — between related article cards
 *   - "bottom"        — end of article, before newsletter
 */

interface Props {
  /** Which placement slot to render */
  placement: 'after-h2' | 'mid-article' | 'sidebar' | 'between-cards' | 'bottom';
  /** Ezoic placeholder ID (assigned in Ezoic dashboard per site) */
  placeholderId?: number;
  /** Optional: override the default min-height for this slot */
  minHeight?: string;
}

const { placement, placeholderId, minHeight } = Astro.props;

// Kill switch — reads from build-time env var
const ezoicEnabled = import.meta.env.EZOIC_ENABLED !== 'false';

// Default placeholder IDs per slot type (override via props or Ezoic dashboard)
const defaultIds: Record<string, number> = {
  'after-h2': 101,
  'mid-article': 102,
  'sidebar': 103,
  'between-cards': 104,
  'bottom': 105,
};

const id = placeholderId ?? defaultIds[placement] ?? 100;

// Default min-heights to prevent CLS
const defaultHeights: Record<string, string> = {
  'after-h2': '280px',
  'mid-article': '280px',
  'sidebar': '600px',
  'between-cards': '120px',
  'bottom': '250px',
};

const height = minHeight ?? defaultHeights[placement] ?? '250px';
---

{ezoicEnabled && (
  <div
    class:list={['ezoic-ad', `ezoic-ad--${placement}`]}
    data-ezoic-ad={id}
    data-placement={placement}
    aria-hidden="true"
  >
    <div
      id={`ezoic-pub-ad-placeholder-${id}`}
      class="ezoic-ad__slot"
      style={`min-height: ${height};`}
    >
      <!-- Ezoic fills this div -->
    </div>
    <span class="ezoic-ad__label">Advertisement</span>
  </div>
)}

<script>
  // Lazy-load Ezoic ads using IntersectionObserver
  // Only activates ad slots when they're about to enter the viewport
  (function() {
    if (typeof window === 'undefined') return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.classList.add('ezoic-ad--visible');
            // Signal Ezoic runtime to fill this slot
            if (typeof (window as any).ezstandalone !== 'undefined') {
              try {
                (window as any).ezstandalone.cmd.push(function() {
                  (window as any).ezstandalone.displayMore(
                    parseInt(el.dataset.ezoicAd || '0', 10)
                  );
                });
              } catch (_) {
                // Ezoic not ready yet, it will auto-fill on load
              }
            }
            observer.unobserve(el);
          }
        });
      },
      {
        rootMargin: '200px 0px', // Start loading 200px before entering viewport
        threshold: 0,
      }
    );

    document.querySelectorAll('.ezoic-ad').forEach((ad) => observer.observe(ad));
  })();
</script>

<style>
  /* ── Base ad container ─────────────────────────────── */
  .ezoic-ad {
    position: relative;
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(148, 163, 184, 0.08);
    border-radius: 8px;
    overflow: hidden;
    transition: opacity 0.3s ease;
    opacity: 0;
    contain: layout style;
  }

  .ezoic-ad--visible {
    opacity: 1;
  }

  .ezoic-ad__slot {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ezoic-ad__label {
    display: block;
    text-align: center;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(148, 163, 184, 0.3);
    padding: 2px 0 4px;
    pointer-events: none;
  }

  /* ── Placement: After H2 ───────────────────────────── */
  .ezoic-ad--after-h2 {
    margin: 1.5rem 0 2rem;
  }

  /* ── Placement: Mid-article ────────────────────────── */
  .ezoic-ad--mid-article {
    margin: 2rem 0;
    clear: both;
  }

  /* ── Placement: Sidebar ────────────────────────────── */
  .ezoic-ad--sidebar {
    position: sticky;
    top: 80px;
    margin-bottom: 1.5rem;
  }

  /* ── Placement: Between cards ──────────────────────── */
  .ezoic-ad--between-cards {
    margin: 1rem 0;
  }

  /* ── Placement: Bottom ─────────────────────────────── */
  .ezoic-ad--bottom {
    margin: 2.5rem 0 1.5rem;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 768px) {
    .ezoic-ad--sidebar {
      position: relative;
      top: 0;
    }

    .ezoic-ad__slot {
      min-height: auto !important;
    }
  }
</style>
